psychic_day3_afternoon_convince_nurse_45b5e78e	psychic	Don't do this. There's been a terrible misunderstanding.	game/scripts/psychic/Day 3/2_Afternoon/2_stay.rpy	141	psychic "[what]"
psychic_day3_afternoon_convince_nurse_6278a23c		The nurse's grip on the gun wavers, her eyes swimming with doubt and fear.	game/scripts/psychic/Day 3/2_Afternoon/2_stay.rpy	145	"[what]"
