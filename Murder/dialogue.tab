lad_day3_escape_3ffb56e6	captain	On my mark.	game/scripts/lad/Day 3/2_Afternoon/2b_escape.rpy	270	captain "[what]"
lad_day3_escape_837cb67e	captain	Three.	game/scripts/lad/Day 3/2_Afternoon/2b_escape.rpy	270	captain "[what]"
